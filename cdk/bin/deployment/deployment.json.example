{
  "projectName": "AMS-AuthServer",
  "account": {
    "id": "123456789012",
    "region": "us-west-2",
    "prodLike": false,
    "isAdc": false
  },
  "dataplaneConfig": {
    "KEYCLOAK_VERSION": "latest",
    "DOMAIN_INTERNET_FACING": true,
    "DOMAIN_HOSTED_ZONE_ID": "Z0123456789ABCDEFGHIJ",
    "DOMAIN_HOSTED_ZONE_NAME": "example.com",
    "KEYCLOAK_AUTH_CONFIG": {
      "realm": "my-realm",
      "enabled": true,
      "clients": [
        {
          "clientId": "my-app",
          "publicClient": true,
          "authorizationServicesEnabled": false,
          "websiteUri": "https://myapp.example.com",
          "redirectUris": ["__PLACEHOLDER_REDIRECT_URI__"],
          "postLogoutRedirectUris": ["__PLACEHOLDER_REDIRECT_URI__"],
          "webOrigins": ["__PLACEHOLDER_WEB_ORIGIN__"]
        }
      ],
      "users": [
        {
          "username": "admin",
          "generatePassword": true,
          "email": "admin@example.com",
          "firstName": "Admin",
          "lastName": "User",
          "enabled": true
        }
      ]
    }
  }
}
