{
  "name": "ams-auth-server",
  "version": "0.1.2",
  "description": "AWS CDK project to deploy Keycloak authentication server",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "bin": {
    "app": "bin/app.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebundle:lambda": "cd lambda/keycloak-config && npm ci && npx tsc && mkdir -p .bundle && cp -r dist/* .bundle/ && cp package.json package-lock.json .bundle/ && cd .bundle && npm install --omit=dev",
    "build": "npm run prebundle:lambda && tsc",
    "watch": "tsc -w",
    "test": "jest --selectProjects cdk keycloak-lambda",
    "test:integration": "jest --selectProjects integration --no-coverage",
    "test:all": "jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.993.0",
    "@eslint/js": "^9.39.1",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/node": "24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "aws-cdk": "2.1107.0",
    "axios": "^1.13.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.14.0",
    "jest": "^30.0.5",
    "jose": "^5.10.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.233.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  }
}
