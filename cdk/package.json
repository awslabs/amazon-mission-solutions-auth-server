{
  "name": "ams-auth-server",
  "version": "0.1.0",
  "description": "AWS CDK project to deploy Keycloak authentication server",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --reporters jest-silent-reporter",
    "test:lambda": "jest -c jest.config.js --selectProjects keycloak-lambda",
    "test:coverage": "jest --coverage",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk synth && cdk deploy --require-approval never",
    "format": "prettier --write \"**/*.{ts,js}\"",
    "format:check": "prettier --check \"**/*.{ts,js}\"",
    "lint": "eslint --max-warnings 10 --fix --ext .js,.ts .",
    "lint:check": "eslint --max-warnings 10 --ext .js,.ts ."
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.848.0",
    "@types/babel__core": "^7.20.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "aws-cdk": "2.1022.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.11.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "jest": "^30.0.5",
    "jest-silent-reporter": "^0.6.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.207.0",
    "constructs": "^10.4.2",
    "fs-extra": "^11.3.0",
    "source-map-support": "^0.5.21"
  }
}
